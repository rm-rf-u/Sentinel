SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=8000
SENTINEL_DB_PATH=./data/sentinel.db
SENTINEL_MODEL_DIR=./data/models
SENTINEL_LOG_LEVEL=INFO

# Tailscale MagicDNS hostname of this machine (used for CORS and WebRTC ICE)
TAILSCALE_HOSTNAME=sentinel.your-tailnet.ts.net

# Path to Firebase Admin SDK service account JSON
FCM_SERVICE_ACCOUNT_JSON=./data/fcm-sa.json

# Camera device index (0 = built-in, 1 = first external USB, etc.)
CAMERA_DEVICE_INDEX=0

# Audio device index (-1 = system default)
MIC_DEVICE_INDEX=-1
