{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "event",
  "title": "Event",
  "description": "A safety event emitted by the event engine",
  "type": "object",
  "required": ["id", "type", "severity", "timestamp", "confidence"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "type": {
      "type": "string",
      "enum": ["zone_violation", "prone_position", "cry_detected"]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "danger"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "details": {
      "type": "object",
      "description": "Type-specific payload",
      "properties": {
        "zone_mode": {
          "type": "string",
          "enum": ["inside", "outside"],
          "description": "zone_violation only"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "prone_position only — how long detected so far"
        }
      }
    }
  }
}
